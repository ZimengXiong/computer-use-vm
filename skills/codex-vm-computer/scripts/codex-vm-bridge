#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BRIDGE_ROOT="${CODEX_VM_BRIDGE_ROOT:-__CODEX_VM_BRIDGE_ROOT__}"

if [ "$BRIDGE_ROOT" != "__CODEX_VM_BRIDGE_ROOT__" ] && [ -x "$BRIDGE_ROOT/bin/codex-vm-bridge" ]; then
  exec "$BRIDGE_ROOT/bin/codex-vm-bridge" "$@"
fi

REPO_ROOT="$(cd "$SCRIPT_DIR/../../.." 2>/dev/null && pwd || true)"
if [ -n "$REPO_ROOT" ] && [ -x "$REPO_ROOT/bin/codex-vm-bridge" ]; then
  exec "$REPO_ROOT/bin/codex-vm-bridge" "$@"
fi

if command -v codex-vm-bridge >/dev/null 2>&1; then
  exec codex-vm-bridge "$@"
fi

exec npx -y computer-use-vm "$@"
